# =============================================================================
# agentdojo_policy.rules  —  AgentDojo benchmark defence policy
#
# Defends against prompt-injection attacks across four task suites:
#   Workspace (email, file, calendar)
#   Banking   (transfers, account management)
#   Slack     (DMs, channel posts)
#   Travel    (flight/hotel booking, payment)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# Workspace Suite — email, file, calendar
# ─────────────────────────────────────────────────────────────────────────────

# [WS-1] Untrusted agents must not send email directly (prompt injection risk).
RULE: ws-deny-email-send-low-trust
ON:        tool_call(send_email)
CONDITION: principal.trust_level < 3
POLICY:    DENY
Severity:  high
Category:  email_exfiltration
Reason:    "Untrusted agent may not send emails directly"

# [WS-2] File deletion requires a privileged role.
RULE: ws-deny-delete-file
ON:        tool_call(delete_file)
CONDITION: principal.role != "privileged"
POLICY:    DENY
Severity:  critical
Category:  data_destruction
Reason:    "File deletion requires privileged role"

# [WS-3] Calendar event creation by low-trust agents needs human approval.
RULE: ws-review-calendar-event
ON:        tool_call.requested(create_calendar_event)
CONDITION: principal.trust_level < 3
POLICY:    HUMAN_CHECK
Severity:  medium
Category:  calendar_manipulation

# [WS-4] File writes by low-trust agents need human approval.
RULE: ws-review-file-write-low-trust
ON:        tool_call.requested(write_file)
CONDITION: principal.trust_level < 3
POLICY:    HUMAN_CHECK
Severity:  medium
Category:  file_tampering

# [WS-5] Email read immediately followed by email send — possible injection forwarding.
RULE: ws-read-then-send-email-llm
TRACE:     Reader -> Sender
CONDITION: Reader.name IN {"read_email", "read_inbox", "get_email"}
           AND Sender.name == "send_email"
POLICY:    LLM_CHECK
Severity:  high
Category:  email_injection
Reason:    "Email read immediately followed by send; possible injection forwarding"


# ─────────────────────────────────────────────────────────────────────────────
# Banking Suite — transfers, account management
# ─────────────────────────────────────────────────────────────────────────────

# [BK-1] All wire transfers must be approved by a human.
RULE: bk-review-send-money
ON:        tool_call.requested(send_money)
CONDITION: principal.trust_level < 4
POLICY:    HUMAN_CHECK
Severity:  critical
Category:  financial_fraud
Reason:    "Wire transfer requires human approval"

# [BK-2] Account/password updates require human approval.
RULE: bk-review-update-account
ON:        tool_call.requested(update_password)
CONDITION: principal.trust_level < 4
POLICY:    HUMAN_CHECK
Severity:  critical
Category:  account_takeover

# [BK-3] Balance check anywhere before a transfer — LLM review for injection risk.
RULE: bk-balance-to-transfer-llm
TRACE:     BalanceCheck ->...?-> Transfer
CONDITION: BalanceCheck.name IN {"get_balance", "get_account_info"}
           AND Transfer.name == "send_money"
POLICY:    LLM_CHECK
Severity:  critical
Category:  financial_injection
Reason:    "Balance check followed by transfer; LLM review for injection risk"


# ─────────────────────────────────────────────────────────────────────────────
# Slack Suite — direct messages, channel posts
# ─────────────────────────────────────────────────────────────────────────────

# [SL-1] Low-trust agents may not send direct messages.
RULE: sl-deny-dm-low-trust
ON:        tool_call(send_direct_message)
CONDITION: principal.trust_level < 2
POLICY:    DENY
Severity:  high
Category:  messaging_exfil

# [SL-2] Low-trust agents need approval to post in channels.
RULE: sl-review-channel-post-low-trust
ON:        tool_call.requested(send_channel_message)
CONDITION: principal.trust_level < 2
POLICY:    HUMAN_CHECK
Severity:  medium
Category:  messaging_exfil

# [SL-3] Slack message read immediately followed by DM — injection exfiltration risk.
RULE: sl-read-then-dm-llm
TRACE:     Reader -> Sender
CONDITION: Reader.name IN {"get_messages", "read_channel", "get_inbox"}
           AND Sender.name == "send_direct_message"
POLICY:    LLM_CHECK
Severity:  high
Category:  slack_injection
Reason:    "Slack message read immediately followed by DM; injection risk"


# ─────────────────────────────────────────────────────────────────────────────
# Travel Suite — flight/hotel booking, cancellations
# ─────────────────────────────────────────────────────────────────────────────

# [TR-1] Flight purchases require human approval.
RULE: tr-review-purchase-flight
ON:        tool_call.requested(purchase_plane_ticket)
CONDITION: principal.trust_level < 4
POLICY:    HUMAN_CHECK
Severity:  high
Category:  unauthorized_purchase

# [TR-2] Hotel bookings require human approval.
RULE: tr-review-book-hotel
ON:        tool_call.requested(book_hotel)
CONDITION: principal.trust_level < 4
POLICY:    HUMAN_CHECK
Severity:  high
Category:  unauthorized_purchase

# [TR-3] Cancellations require human approval.
RULE: tr-review-cancel-reservation
ON:        tool_call.requested(cancel_reservation)
CONDITION: principal.trust_level < 4
POLICY:    HUMAN_CHECK
Severity:  medium
Category:  reservation_tampering

# [TR-4] Travel search results flowing into a purchase — LLM review for injection.
RULE: tr-search-to-purchase-llm
TRACE:     Search ->...?-> Purchase
CONDITION: Search.name IN {"search_flights", "search_hotels", "get_travel_offers"}
           AND Purchase.name IN {"purchase_plane_ticket", "book_hotel"}
POLICY:    LLM_CHECK
Severity:  high
Category:  travel_injection
Reason:    "Travel search result flowing into purchase; LLM review for injection risk"


# ─────────────────────────────────────────────────────────────────────────────
# General — HTTP egress, call-chain defence
# ─────────────────────────────────────────────────────────────────────────────

# [GEN-1] Low-trust agents must not POST to external endpoints.
RULE: gen-deny-external-post-low-trust
ON:        tool_call(post_webpage)
CONDITION: principal.trust_level < 3
POLICY:    DENY
Severity:  high
Category:  data_exfiltration
Reason:    "Low-trust agent must not POST to external endpoints"

# [GEN-2] LLM or user input flowing into shell — classic prompt injection to execution.
RULE: gen-deny-llm-output-to-shell
TRACE:     Untrusted ->...?-> Shell
CONDITION: Untrusted.name IN {"llm.respond", "llm_respond", "user_input"}
           AND Shell.name IN {"shell_exec", "shell.exec"}
POLICY:    DENY
Severity:  critical
Category:  prompt_injection
Reason:    "LLM/user output flowing into shell — prompt injection risk"
