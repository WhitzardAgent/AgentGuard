# ── 7.3  HR data → external sinks ────────────────────────────────────

RULE: builtin_hr_http_export_block
ON: tool_call(http.post)
CONDITION: exists_path(source.label IN {"hr/*"}, max_hops = 6)
           AND target.domain NOT IN allowlist.http
POLICY: DENY
