{
  "id": "agentguard",
  "activation": {
    "onStartup": true
  },
  "uiHints": {
    "configPath": {
      "label": "AgentGuard Config Path",
      "help": "Path to the AgentGuard JSON config file used by this OpenClaw plugin."
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["configPath"],
    "properties": {
      "configPath": {
        "type": "string"
      }
    }
  }
}
